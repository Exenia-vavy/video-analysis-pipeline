# ============================================
# TEMPLATE DE CONFIGURATION
# Copiez ce fichier en .env et ajoutez vos vraies clés
# ============================================

# Clé API pour Qwen-VL (OpenRouter) - REQUIS pour PZ7
# Obtenez-la sur : https://openrouter.ai/keys
# ⚠️ Ne mettez JAMAIS de vraie clé ici
LLM_API_KEY=CHANGE_ME_OPENROUTER_KEY_HERE

# Clé API pour Gemini (Google AI Studio) - OPTIONNEL
# Si tu n'as pas de clé, laisse tel quel ou supprime la ligne
# Obtenez-la sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY_HERE

# Chemins (ne pas modifier sauf besoin spécial)
INPUT_DIR=./input
OUTPUT_DIR=./output